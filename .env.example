# Copy this file to .env for local NetConfEval reproduction runs.
# Do not commit real secrets or credentials.

# The paper scripts accept either OPENAI_API_KEY or DEEPSEEK_API_KEY.
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# OpenAI-compatible endpoint used by DeepSeek runs.
DEEPSEEK_BASE_URL=https://api.deepseek.com
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_API_BASE=https://api.deepseek.com

# Default model and runner settings.
NETCONFEVAL_MODEL=deepseek-v4-flash
NETCONFEVAL_PROVIDER_MODEL=deepseek-v4-flash
NETCONFEVAL_N_RUNS=1
NETCONFEVAL_REQUEST_TIMEOUT=90
NETCONFEVAL_MAX_TOKENS=8192
