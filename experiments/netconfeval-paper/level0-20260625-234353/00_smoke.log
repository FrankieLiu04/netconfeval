import collections

def compute_routing_paths(topo: Dict[str, Dict[int, str]]) -> Dict[str, Dict[str, List[str]]]:
    # Build graph: adjacency list of devices
    graph = collections.defaultdict(set)
    # Build LAN to devices mapping
    lan_to_devices = collections.defaultdict(set)
    for device, ports in topo.items():
        for port, lan in ports.items():
            lan_to_devices[lan].add(device)
    # Add edges between devices sharing a LAN
    for lan, devices in lan_to_devices.items():
        dev_list = list(devices)
        for i in range(len(dev_list)):
            for j in range(i+1, len(dev_list)):
                graph[dev_list[i]].add(dev_list[j])
                graph[dev_list[j]].add(dev_list[i])
    # Identify hosts (device names starting with 'h')
    hosts = [dev for dev in topo if dev.startswith('h')]
    # BFS to find shortest path between two devices
    def bfs_shortest_path(start: str, goal: str) -> List[str]:
        visited = set()
        queue = collections.deque([[start]])
        while queue:
            path = queue.popleft()
            node = path[-1]
            if node == goal:
                return path
            if node not in visited:
                visited.add(node)
                for neighbor in graph[node]:
                    if neighbor not in visited:
                        new_path = list(path) + [neighbor]
                        queue.append(new_path)
        return []  # no path
    # Build result dictionary
    result = {}
    for src in hosts:
        result[src] = {}
        for dst in hosts:
            if src == dst:
                continue
            path = bfs_shortest_path(src, dst)
            if path:
                result[src][dst] = path
    return result, data={'extend': True, 'input': '\n', 'metadata': {'test_path': '/workspace/research/netconfeval/assets/step_2_tests/path_tests'}}
